{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "401ff46c9a1641aea7a99cbd40d6e205",
    "m_Title": "",
    "m_Content": "For missing Varying Reference Types, the <Linkage> hint allows querying the input connection state.\n\nThis is similar to using BranchOnInputConnection in a Subgraph.\n\nFor instance, this allows to default to built-in variables such as unity_AmbientSky or UNITY_MATRIX_V[2].\n\nThe <CustomBinding> hint allows for labeling inputs ports of linked parameters.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -2906.0,
        "y": 346.0,
