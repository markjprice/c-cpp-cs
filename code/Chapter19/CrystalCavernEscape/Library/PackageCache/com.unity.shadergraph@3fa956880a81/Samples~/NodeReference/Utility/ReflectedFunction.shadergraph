    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "247130bf3875444f81b20436820239fd",
    "m_Title": "",
    "m_Content": "In this basic example, we're multiplying the 'inout' color parameter by a multiplier parameter.\n\nReflected Functions can use a return type, out or inout parameters to feature an Output Port.\n\nThe multiplier shows as a slider with no input port by using the <Static /> hint.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -4417.0,
        "y": 475.0,
