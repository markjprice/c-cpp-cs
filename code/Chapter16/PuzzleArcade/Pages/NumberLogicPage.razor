@page "/number-logic"

@using PuzzleArcade.Games.NumberLogic

<PageTitle>Number Logic</PageTitle>

<GamePanel Title="Number Logic"
           Instructions="Guess the hidden digit sequence using the clues from each attempt.">
  <GameStatusBar State="model.State"
                 Detail="@StatusDetail"
                 LastAction="lastAction" />

  <GameCommandBar State="model.State"
                  ShowGuessForm="true"
                  GuessLabel="Digits:"
                  MaxGuessLength="4"
                  GuessInputId="number-logic-input"
                  OnAction="Dispatch" />

  <p>@model.Message</p>

    <!-- Comment out the following <p> before deploying. -->
    <p><strong>Debug secret:</strong> @model.Secret</p>

@if (model.Attempts.Count > 0)
{
  <h2>Attempts</h2>

  <table class="attempt-table">
    <thead>
      <tr>
        <th>Guess</th>
        <th>Exact</th>
        <th>Misplaced</th>
        <th>Summary</th>
      </tr>
    </thead>
    <tbody>
      @foreach (NumberLogicAttempt attempt in model.Attempts)
      {
        <tr>
          <td class="digit-guess">@attempt.Guess</td>
          <td>@attempt.Clue.ExactMatches</td>
          <td>@attempt.Clue.MisplacedMatches</td>
          <td>@attempt.ClueText</td>
        </tr>
      }
    </tbody>
  </table>
}
</GamePanel>

@code {
    private NumberLogicModel model = NumberLogicRules.CreateInitial();
    private PuzzleAction lastAction;

    private string StatusDetail =>
        model.State switch
        {
            Playing => $"Attempts remaining: {model.AttemptsRemaining}",
            Won => "The round is complete.",
            Lost => "The round is complete.",
            _ => model.Message
        };

    private void Dispatch(PuzzleAction action)
    {
        lastAction = action;
        model = NumberLogicRules.Update(model, action);
    }
}
